# ────────────────────────────────────────
#  تنظیمات ربات 3X-UI
#  این فایل را کپی کنید به .env و پر کنید
# ────────────────────────────────────────

# توکن ربات تلگرام (از @BotFather بگیرید)
BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ

# شماره کارت برای واریز (بدون فاصله یا خط تیره)
CARD_NUMBER=6037991234567890

# نام صاحب کارت
CARD_OWNER=علی محمدی

# (اختیاری) آی‌دی عددی ادمین‌های مجاز، با کاما جدا کنید
# اگه خالی باشد همه می‌توانند /setup بزنند
ALLOWED_ADMINS=
